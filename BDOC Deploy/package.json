{
  "name": "kgs-bdoc",
  "version": "8.0.0",
  "private": true,
  "description": "KGS BDOC — Military-grade geospatial intelligence platform. Offline-capable desktop app.",
  "author": {
    "name": "Kitsune Global Solutions LLC",
    "email": "support@kgsbdoc.netlify.app"
  },
  "license": "UNLICENSED",
  "main": "electron/main.js",
  "scripts": {
    "start": "node -e \"require('./electron/server').createServer().listen(9080, () => console.log('BDOC local server: http://localhost:9080'))\"",
    "electron": "electron .",
    "electron:dev": "NODE_ENV=development electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --win --mac --linux"
  },
  "dependencies": {
    "stripe": "^17.5.0",
    "@supabase/supabase-js": "^2.49.4",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.kitsuneglobal.bdoc",
    "productName": "KGS BDOC",
    "copyright": "Copyright © 2026 Kitsune Global Solutions LLC",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "index.html",
      "manifest.json",
      "service-worker.js",
      "robots.txt",
      "sitemap.xml",
      "css/**",
      "js/**",
      "assets/**",
      "*.json",
      "*.svg",
      "*.kml",
      "electron/**",
      "netlify/functions/**",
      "!dist-electron/**",
      "!node_modules/.cache/**"
    ],
    "extraFiles": [
      {
        "from": "assets",
        "to": "assets"
      }
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "BDOC-Setup-${version}.${ext}"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.utilities",
      "artifactName": "BDOC-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ],
      "icon": "assets/icon.png",
      "category": "Utility",
      "artifactName": "BDOC-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "KGS BDOC"
    }
  }
}
